{UTF-8}
Average SLB Lifetime=8
	~	
	~		|

Base Collection Efficiency=0.55
	~	
	~		|

Base Deployment Demand=2200
	~	
	~		|

Base Diagnosis Capacity=3500
	~	
	~		|

Base Diagnostic Capability=0.4
	~	
	~		|

Base Failure Risk=0.2
	~	
	~		|

Base Governance Effectiveveness=0.45
	~	
	~		|

Base Market Attractiveness=0.45
	~	
	~		|

Base Recycling Capacity=1800
	~	
	~		|

Base Repurposing Capacity=2500
	~	
	~		|

Base Standardization Level=0.35
	~	
	~		|

Batteries to Recycling= INTEG (SLB Retirement Rate + Failed Battery Transfer to Recycling\
		 - Recycling Rate,
		0)
	~	
	~		|

Collected Batteries= INTEG (Collection Rate - Diagnosis Rate,
		0)
	~	
	~		|

Collection Efficiency=MIN(0.95,
	Base Collection Efficiency
	* (0.5 + Governance Effectivenes)
	)
	~	
	~		|

Collection Rate=MIN(EV Battery EoL Available,
	EOL Generation * Collection Efficiency)
	~	
	~		|

Cost Pressure=0.15
	~	
	~		|

Cumulative Emission Reduction= INTEG (Emission Reduction Rate,
		0)
	~	
	~		|

Deployment Demand=Base Deployment Demand* (0.5 + Market Attractiveness)
	~	
	~		|

Deployment Rate=MIN ( Deployment Demand , Repurposed Batteries )
	~	
	~		|

Diagnosed Batteries= INTEG (Diagnosis Rate - Repurposing Rate,
		0)
	~	
	~		|

Diagnosis Accuracy=MIN(0.98,
	0.3 + 0.5 * Diagnostic Capability + 0.2 * Standardization Level
	)
	~	
	~		|

Diagnosis Capacity=Base Diagnosis Capacity * (0.5 + Diagnostic Capability)
	~	
	~		|

Diagnosis Rate=MIN ( Collected Batteries , Diagnosis Capacity )
	~	
	~		|

Diagnostic Capability=MIN(1, MAX(0,
	Base Diagnostic Capability
	+ Diagnostic Investment Rate * (Time - INITIAL TIME)
	))
	~	
	~		|

Diagnostic Investment Rate=0.01
	~	
	~		|

Emission Benefit per Unit=250
	~	
	~		|

Emission Reduction Rate=(SLB in Use * Emission Benefit per Unit)
	- (Repurposing Rate * Repurposing Emission per Unit)
	- (Recycling Rate * Recycling Emission per Unit)
	~	
	~		|

EOL Generation=Initial EoL Generation*EXP ( EoL Growth Rate*(Time-INITIAL TIME) )
	~	Dmnl
	~		|

EoL Growth Rate=0.08
	~	
	~		|

EV Battery EoL Available= INTEG (EOL Generation - Collection Rate,
		10000)
	~	
	~		|

Failed Battery Transfer Delay=1
	~	
	~		|

Failed Battery Transfer to Recycling=Failed SLB/Failed Battery Transfer Delay
	~	
	~		|

Failed SLB= INTEG (Premature Failure Rate - Failed Battery Transfer to Recycling,
		0)
	~	
	~		|

Failure Risk=MIN(0.4, Base Failure Risk* (1 - Diagnosis Accuracy) * (1.2 - Standardization Level\
		))
	~	
	~		|

Governance Effectivenes=MIN(1, MAX(0, Base Governance Effectiveveness + Governance Improvement Rate\
		 * (Time - INITIAL TIME)
	))
	~	
	~		|

Governance Improvement Rate=0.01
	~	
	~		|

Incentive Level=0.2
	~	
	~		|

Initial EoL Generation=1000
	~	
	~		|

Market Attractiveness=MIN(1, MAX(0, Base Market Attractiveness + Incentive Level
	- Cost Pressure ))
	~	
	~		|

Premature Failure Rate=Failure Risk*SLB in Use
	~	
	~		|

Recycling Capacity=Base Recycling Capacity * (0.5 + Governance Effectivenes)
	~	
	~		|

Recycling Emission per Unit=50
	~	
	~		|

Recycling Rate=MIN ( Batteries to Recycling , Recycling Capacity )
	~	
	~		|

Repurposed Batteries= INTEG (Repurposing Rate - Deployment Rate,
		0)
	~	
	~		|

Repurposing Capacity=Base Repurposing Capacity* (0.5 + Standardization Level)
	~	
	~		|

Repurposing Emission per Unit=40
	~	
	~		|

Repurposing Rate=MIN ( Diagnosed Batteries * Repurposing Yield , Repurposing Capacity\
		 )
	~	
	~		|

Repurposing Yield=MIN(0.95, 0.3 + 0.4 * Diagnosis Accuracy + 0.3 * Standardization Level
	)
	~	
	~		|

SLB in Use= INTEG (Deployment Rate - SLB Retirement Rate - Premature Failure Rate,
		0)
	~	
	~		|

SLB Retirement Rate=SLB in Use/Average SLB Lifetime
	~	
	~		|

Standardization Improvement Rate=0.01
	~	
	~		|

Standardization Level=MIN(1, MAX(0,
	Base Standardization Level
	+ Standardization Improvement Rate * (Time - INITIAL TIME)
	))
	~	
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 75
	~	Years
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	Years
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP
	~	Years [0,?]
	~	The frequency with which output is stored.
	|

TIME STEP  = 1
	~	Years [0,?]
	~	The time step for the simulation.
	|

